// 1. Setup loaders and the Loading Manager
const loadingManager = new THREE.LoadingManager();
const textureLoader = new THREE.TextureLoader(loadingManager);
const fbxLoader = new FBXLoader(loadingManager);

// 2. Define the textures for all assets
const textures = {
    rock: {
        color: textureLoader.load('assets/smallrocksColor.png'),
        normal: textureLoader.load('assets/smallrocksNormal.png')
    },
    tree: {
        color: textureLoader.load('assets/oak-treesColor.png')
    },
    grass: {
        color: textureLoader.load('assets/grassColor.png')
    }
};

// 3. Helper function to apply materials to FBX groups
const applyEnvironmentMaterial = (group, material) => {
    group.traverse((child) => {
        if (child.isMesh) {
            child.material = material;
            child.castShadow = true;
            child.receiveShadow = true;
            // Matches 'CullingOff' metadata for rocks and transparency for grass/leaves[cite: 1]
            child.material.side = THREE.DoubleSide; 
        }
    });
    scene.add(group);
};

// 4. Load the Assets

// Load Rocks[cite: 1]
fbxLoader.load('assets/rocks.fbx', (fbx) => {
    const rockMat = new THREE.MeshStandardMaterial({
        map: textures.rock.color,
        normalMap: textures.rock.normal,
        roughness: 0.8
    });
    applyEnvironmentMaterial(fbx, rockMat);
});

// Load Trees
fbxLoader.load('assets/oak-trees.fbx', (fbx) => {
    const treeMat = new THREE.MeshStandardMaterial({
        map: textures.tree.color,
        alphaTest: 0.5 // Helps with leaf transparency
    });
    applyEnvironmentMaterial(fbx, treeMat);
});

// Load Grass
fbxLoader.load('assets/grass.fbx', (fbx) => {
    const grassMat = new THREE.MeshStandardMaterial({
        map: textures.grass.color,
        alphaTest: 0.5,
        transparent: true
    });
    applyEnvironmentMaterial(fbx, grassMat);
});
